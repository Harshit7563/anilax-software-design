{
  "appId": "com.anilaxsoftware.admin",
  "appName": "Anilax Admin",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["anilaxsoftware.com", "*.anilaxsoftware.com"]
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0f"
    }
  }
}
