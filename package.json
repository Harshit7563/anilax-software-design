{
  "name": "anilax-software-design",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:all": "node server/index.js & vite",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-3000}",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "cap:sync": "npm run build:android && npx cap sync android",
    "cap:open": "npx cap open android",
    "android": "npm run cap:sync && npx cap open android",
    "android:apk": "npm run cap:sync && cd android && ./gradlew --stop && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../Anilax-Admin-debug.apk && echo 'APK: Anilax-Admin-debug.apk'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "serve": "^14.2.4",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vitest": "^3.2.6"
  }
}
